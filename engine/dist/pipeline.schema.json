{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://apm.dev/schemas/pipeline.schema.json",
  "title": "QuorumKit Pipeline",
  "description": "Declarative pipeline definition for QuorumKit Orchestrator (v1 + v2)",
  "oneOf": [
    { "$ref": "#/definitions/v1" },
    { "$ref": "#/definitions/v2" }
  ],
  "definitions": {
    "v1": {
      "type": "object",
      "required": ["name", "version", "trigger", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "version": { "type": "string", "enum": ["1"] },
        "schema_version": { "type": "string", "enum": ["1"] },
        "apiVersion": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "trigger": { "$ref": "#/definitions/trigger" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/v1Step" }
        }
      }
    },
    "v2": {
      "type": "object",
      "required": ["name", "schema_version", "trigger", "entry", "steps", "transitions"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "schema_version": { "type": "string", "enum": ["2"] },
        "apiVersion": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
        "trigger": { "$ref": "#/definitions/trigger" },
        "entry": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/v2Step" }
        },
        "transitions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/transition" }
        },
        "loop_budget": { "$ref": "#/definitions/loopBudget" }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["event"],
      "additionalProperties": false,
      "properties": {
        "event": { "type": "string", "minLength": 1 },
        "labels": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "state": { "type": "string" }
      }
    },
    "v1Step": {
      "type": "object",
      "required": ["name", "agent"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "minLength": 1 },
        "condition": { "type": "string" },
        "approval": { "type": "string", "enum": ["required"] },
        "approval_timeout_hours": { "type": "integer", "minimum": 1 }
      }
    },
    "v2Step": {
      "type": "object",
      "required": ["name", "agent"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "minLength": 1 },
        "condition": { "type": "string" },
        "approval": { "type": "string", "enum": ["required"] },
        "approval_timeout_hours": { "type": "integer", "minimum": 1 },
        "timeout_minutes": { "type": "integer", "minimum": 1 }
      }
    },
    "transition": {
      "type": "object",
      "required": ["from", "outcome", "to"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "loopBudget": {
      "type": "object",
      "required": ["max_iterations_per_edge", "max_total_steps", "max_wallclock_minutes"],
      "additionalProperties": false,
      "properties": {
        "max_iterations_per_edge": { "type": "integer", "minimum": 1 },
        "max_total_steps": { "type": "integer", "minimum": 1 },
        "max_wallclock_minutes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
